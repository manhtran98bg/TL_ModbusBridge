<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20"/>
    </Design.PreviewWith>

    <Style Selector="Button.small">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#7f98c7"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <Style Selector="Button.small /template/ ContentPresenter">
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.small:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#98acd0"/>
        <Setter Property="TextBlock.Foreground" Value="White"/>
        <Setter Property="RenderTransform" Value="scale(0.96)"/>
    </Style>

    <Style Selector="Button.small:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="#CBD5E1"/>
        <Setter Property="TextBlock.Foreground" Value="#64748B"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

    <Style Selector="TextBox">
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="CornerRadius" Value="8"/>
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>
</Styles>
