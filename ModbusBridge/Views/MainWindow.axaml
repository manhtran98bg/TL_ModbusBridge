<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ModbusBridge.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="560"
        Width="920" Height="560"
        x:Class="ModbusBridge.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ModbusBridge">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="20">
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding StatusMessage}" Opacity="0.75"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,16,0,16">
            <Button Content="Start" Command="{Binding StartCommand}"/>
            <Button Content="Stop" Command="{Binding StopCommand}"/>
        </StackPanel>

        <Border Grid.Row="2" BorderBrush="#D5D9E0" BorderThickness="1" Padding="12" Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,*,*,*">
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Modbus requests" Opacity="0.7"/>
                    <TextBlock Text="{Binding ModbusRequestCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Modbus errors" Opacity="0.7"/>
                    <TextBlock Text="{Binding ModbusErrorCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="PLC writes" Opacity="0.7"/>
                    <TextBlock Text="{Binding PlcWriteCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="PLC errors" Opacity="0.7"/>
                    <TextBlock Text="{Binding PlcErrorCount}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3">
            <ItemsControl ItemsSource="{Binding ChannelStatuses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChannelStatusViewModel">
                        <Border BorderBrush="#D5D9E0" BorderThickness="1" Padding="12" Margin="0,0,0,10">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="150,120,110,110,130,120,*">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PortName}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding State}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding LastReadElapsed}"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="{Binding LastTarget}"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding LastSuccessTime}"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding LastErrorTime}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" Text="Requests" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding RequestCount}"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" Text="Errors" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,8,0,0" Text="{Binding ErrorCount}"/>
                                <TextBlock Grid.Row="1" Grid.Column="5" Margin="0,8,0,0" Text="Last OK" Opacity="0.7"/>
                                <TextBlock Grid.Row="1" Grid.Column="6" Margin="0,8,0,0" Text="Last Error" Opacity="0.7"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7" Margin="0,8,0,0"
                                           Text="{Binding Message}" TextWrapping="Wrap" Opacity="0.75"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
